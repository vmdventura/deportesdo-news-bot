# Bot de Telegram (@deportesdo_news_bot — token de BotFather)
TELEGRAM_BOT_TOKEN=
# IDs de Telegram autorizados, separados por coma (vacío = todos)
TELEGRAM_ALLOWED_USERS=

# WordPress de DeportesDO (usuario con rol Editor + Application Password)
WORDPRESS_URL=https://deportesdo.com
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=

# API de Anthropic para la redacción
ANTHROPIC_API_KEY=
